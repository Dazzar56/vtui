func NewGogpuRenderer(host *GogpuHost, face text.Face, cw, ch int) *GogpuRenderer {
	return &GogpuRenderer{
		host:            host,
		face:            face,
		cellW:           cw,
		cellH:           ch,
		lastCursorReset: time.Now(),
	}
}

